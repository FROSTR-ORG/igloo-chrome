{
  "name": "igloo-chrome",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "node ./scripts/build.mjs",
    "build": "node ./scripts/build.mjs",
    "build:bridge-wasm": "./scripts/build-bridge-wasm.sh",
    "test:e2e": "playwright test -c test/playwright.config.ts",
    "test:ci": "npm run build:bridge-wasm && npm run test:e2e && npm run build",
    "package": "node ./scripts/package-release.mjs",
    "release:candidate": "npm run build:bridge-wasm && bunx tsc --noEmit && npm run build && npm run test:e2e && npm run package"
  },
  "dependencies": {
    "lucide-react": "^0.453.0",
    "nostr-tools": "^2.17.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.54.2",
    "@scure/base": "^1.2.6",
    "@types/node": "^24.10.1",
    "@types/react": "^18.3.5",
    "@types/react-dom": "^18.3.0",
    "@types/ws": "^8.18.1",
    "esbuild": "^0.25.0",
    "postcss": "^8.4.47",
    "tailwindcss": "^3.4.14",
    "typescript": "^5.5.4",
    "ws": "^8.18.3"
  }
}
