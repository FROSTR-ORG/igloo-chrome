{
  "name": "igloo-chrome",
  "version": "0.2.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build:ui": "npm --prefix ../igloo-ui run build",
    "dev": "npm run build:ui && npm run build:bridge-wasm && node ./scripts/build.mjs",
    "build": "npm run build:ui && npm run build:bridge-wasm && node ./scripts/build.mjs",
    "build:bridge-wasm": "node ./scripts/sync-bridge-wasm.mjs",
    "test:unit": "vitest run",
    "test:e2e": "npm --prefix ../../test run test:e2e:igloo-chrome",
    "test:ci": "npm run build:bridge-wasm && npm run test:unit && npm run test:e2e && npm run build",
    "package": "node ./scripts/package-release.mjs",
    "release:candidate": "npm run build:bridge-wasm && bunx tsc --noEmit && npm run build && npm run test:e2e && npm run package"
  },
  "dependencies": {
    "igloo-shared": "file:../igloo-shared",
    "igloo-ui": "file:../igloo-ui",
    "lucide-react": "^0.453.0",
    "nostr-tools": "^2.17.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.54.2",
    "@scure/base": "^1.2.6",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^24.10.1",
    "@types/react": "^18.3.5",
    "@types/react-dom": "^18.3.0",
    "@types/ws": "^8.18.1",
    "esbuild": "^0.25.0",
    "jsdom": "^28.1.0",
    "postcss": "^8.4.47",
    "tailwindcss": "^3.4.14",
    "typescript": "^5.5.4",
    "vitest": "^4.0.18",
    "ws": "^8.18.3"
  }
}
